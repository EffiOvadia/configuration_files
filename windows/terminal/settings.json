            },
            {
                // Fedora Linux 42
                "commandline": "wsl -d FedoraLinux-42 -u root",
                "guid": "{a0f3061c-98fd-59a9-a019-beb08917bb7d}",
                "hidden": false,
                "icon": "ms-appdata:///Local/Fedora.ico",
                "name": "FedoraLinux 42",
                "source": "Microsoft.WSL"
            },
            {
                // Arch Linux
                "commandline": "wsl -d archlinux -u root",
                "guid": "{83c45d7f-60fd-59f5-aedd-e1c44f2a85cb}",
                "hidden": false,
                "icon": "ms-appdata:///Local/Arch.ico",
                "name": "ArchLinux",
                "source": "Microsoft.WSL"
            },
            {
                // AlmaLinux 10
                "commandline": "wsl -d AlmaLinux-Kitten-10 -u effio",
                "guid": "{fc0b5fcb-9c82-58c1-a53c-00e60da1ee54}",
                "hidden": false,
                "name": "AlmaLinux Kitten 10",
                "source": "Microsoft.WSL"
            },
            {
                // Python 3.13
                "commandline": "python3.13.exe",
                "foreground": "#BBB000",
                "guid": "{705eda2e-4518-4ad1-94de-763afb1bab2a}",
                "hidden": true,
                "icon": "ms-appdata:///Local/Python.ico",
                "name": "Python",
                "useAcrylic": true
            },
            {
                // Command Prompt
                "foreground": "#BBB000",
                "guid": "{0caa0dad-35be-5f56-a8ff-afceeeaa6101}",
                "hidden": true,
                "name": "Command Prompt",
                "startingDirectory": "%SYSTEMDRIVE%/",
                "useAcrylic": true
            },
            {
                // Git Bash
                "foreground": "#BCC000",
                "guid": "{2ece5bfe-50ed-5f3a-ab87-5cd4baafed2b}",
                "hidden": true,
                "icon": "ms-appdata:///Local/git.ico",
                "name": "Git Bash",
                "source": "Git",
                "startingDirectory": "~/git",
                "useAcrylic": true
            }
        ]
    },
