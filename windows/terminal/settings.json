{
    "$help": "https://aka.ms/terminal-documentation",
    "$schema": "https://aka.ms/terminal-profiles-schema",
    "actions": [],
    "alwaysShowNotificationIcon": false,
    "centerOnLaunch": true,
    "copyFormatting": "none",
    "copyOnSelect": true,
    "defaultInputScope": "alphanumericHalfWidth",
    "defaultProfile": "{574e775e-4f2a-5b96-ac1e-a2962a402336}",
    "disabledProfileSources": [ "Windows.Terminal.Azure"],
    "firstWindowPreference": "persistedWindowLayout",
    "focusFollowMouse": false,
    "initialCols": 140,
    "initialPosition": "300,100",
    "initialRows": 35,
    "keybindings": 
    [
        { "id": "Terminal.DuplicatePaneAuto", "keys": "alt+shift+d" },
        { "id": "Terminal.CopyToClipboard", "keys": "ctrl+c"},
        { "id": "Terminal.FindText", "keys": "ctrl+shift+f"},
        { "id": "Terminal.PasteFromClipboard", "keys": "ctrl+v" }
    ],
    "language": "en-US",
    "launchMode": "default",
    "newTabMenu": [ { "type": "remainingProfiles"}],
    "profiles": 
    {
        "defaults": 
        {
            "antialiasingMode": "grayscale",
            "backgroundImageAlignment": "bottomRight",
            "backgroundImageOpacity": 0.08,
            "backgroundImageStretchMode": "uniform",
            "bellStyle": [ "audible", "window", "taskbar" ],
            "closeOnExit": "graceful",
            "colorScheme": "Warm",
            "cursorColor": "#00CCFF",
            "cursorShape": "filledBox",
            "font": 
            {
                "face": "Cascadia Code NF", "size": 14, "weight": "extra-light",
                "features": { "onum": 1, "ss01": 1, "ss02": 1, "ss03": 1, "ss04": 1, "ss05": 1, "ss06": 1, "zero": 1 },
                "axes": { "ital": 0, "slnt": -10, "wght": 200 }
            },
            "historySize": 9001,
            "intenseTextStyle": "all",
            "opacity": 90,
            "padding": "5, 5, 5, 5",
            "pathTranslationStyle": "wsl",
            "showMarksOnScrollbar": true,
            "snapOnInput": true,
            "startingDirectory": "~"
        },
        "list": 
        [
            {
                // PowerShell core
                "adjustIndistinguishableColors": "always",
                "backgroundImage": "ms-appdata:///Local/powershell.png",
                "commandline": "pwsh -NoLogo -WorkingDirectory ~",
                "guid": "{574e775e-4f2a-5b96-ac1e-a2962a402336}",
                "hidden": false,
                "name": "PowerShell \u26a1",
                "source": "Windows.Terminal.PowershellCore"
            },
            {
                // Windows PowerShell
                "adjustIndistinguishableColors": "always",
                "backgroundImage": "ms-appdata:///Local/powershell.png",
                "commandline": "powershell.exe -NoLogo",
                "cursorColor": "#00CCFF",
                "guid": "{61c54bbd-c2c6-5271-96e7-009a87ff44bf}",
                "hidden": true,
                "name": "PowerShell",
                "startingDirectory": "%USERPROFILE%"
            },
            {
                // Cygwin X64
                "adjustIndistinguishableColors": "always",
                "backgroundImage": "ms-appdata:///Local/cygwin.png",
                "commandline": "%SystemDrive%/Cygwin64/bin/bash --login -i",
                "cursorColor": "#00FF00",
                "guid": "{a8029c17-5fa8-48d3-ba23-8c158ac3785f}",
                "hidden": false,
                "icon": "ms-appdata:///Local/cygwin.ico",
                "name": "Cygwin"
            },
            {
